us":true,"order":5,"created_at":"2025-12-08T13:45:25.000000Z","updated_at":"2025-12-08T13:45:25.000000Z","deleted_at":null}],"extra_menu":[{"id":203,"bg_color":"#E74C3C","bg_color_hover":null,"text_color":"#FFFFFF","text_color_hover":null,"title":"LOGIN","target":"_self","url":"https:\/\/client.tradertok.com\/\/#\/auth\/login?lang=en","content":null,"location":"top","image":null,"show":true,"status":true,"order":null,"row_column":1,"created_at":"2025-07-03T10:34:51.000000Z","updated_at":"2025-10-31T12:18:53.000000Z","deleted_at":null,"customer_id":168}],"popup":[],"other_page":[],"blog":[],"blog_category":[],"properties":[],"accounts":[],"questions":[{"id":275,"customer_id":168,"title":"Lightning-Fast Execution","content":"<p align=\"justify\" style=\"line-height: 1.6; margin-bottom: 0.5em; direction: ltr; font-size: medium;\">Every millisecond counts in trading. Our advanced infrastructure ensures your orders are\r\nexecuted quickly, reliably, and with minimal slippage, so you never miss an opportunity.<\/p>","order":1,"status":true,"created_at":"2025-07-03T10:23:40.000000Z","updated_at":"2025-10-31T11:33:20.000000Z","deleted_at":null},{"id":276,"customer_id":168,"title":"Cutting-Edge Platforms","content":"<p align=\"justify\" style=\"line-height: 1.6; margin-bottom: 0.5em; direction: ltr; background: transparent;  font-size: medium;\">Trade on TraderTool, our own intuitive platform. With advanced charts, powerful analytics,\r\nand customizable tools, you have everything you need to trade smarter&nbsp;<\/p>","order":2,"status":true,"created_at":"2025-07-03T10:24:29.000000Z","updated_at":"2025-10-31T11:36:12.000000Z","deleted_at":null},{"id":277,"customer_id":168,"title":"Global Markets, Local Insights","content":"<p align=\"justify\" style=\"line-height: 1.6; margin-bottom: 0.5em; direction: ltr; background: transparent;  font-size: medium;\">Access a wide range of financial instruments, from forex and commodities to indices and\r\ncryptocurrencies. Our global reach is complemented by expert market insights to help you\r\nmake informed decisions.&nbsp;<\/p>","order":3,"status":true,"created_at":"2025-07-03T10:26:12.000000Z","updated_at":"2025-10-31T11:36:45.000000Z","deleted_at":null},{"id":278,"customer_id":168,"title":"Competitive Pricing & Tight Spreads","content":"<p align=\"justify\" style=\"line-height: 1.6; margin-bottom: 0.5em; direction: ltr; background: transparent; font-size: medium;\">We offer market-leading spreads, low fees, and transparent pricing \u2014 designed to give you\r\nthe edge in every trade.&nbsp;<\/p>","order":4,"status":true,"created_at":"2025-07-03T10:26:36.000000Z","updated_at":"2025-10-31T11:37:02.000000Z","deleted_at":null},{"id":346,"customer_id":168,"title":"Expert Support","content":"<p align=\"justify\" style=\"line-height: 1.6; margin-bottom: 0.5em; direction: ltr; background: transparent;  font-size: medium;\">Our dedicated support team is available whenever you need them. We combine industry\r\nknowledge with fast, friendly service, so you can focus on trading with confidence.&nbsp;<\/p>","order":5,"status":true,"created_at":"2025-10-31T11:34:52.000000Z","updated_at":"2025-10-31T11:37:10.000000Z","deleted_at":null},{"id":347,"customer_id":168,"title":"Security & Trust","content":"<p>Your funds and data are safeguarded with industry-standard security protocols and robust\r\naccount protection. Trade with confidence knowing that your investments are secure.<\/p>","order":6,"status":true,"created_at":"2025-10-31T11:35:14.000000Z","updated_at":"2025-10-31T11:35:14.000000Z","deleted_at":null},{"id":348,"customer_id":168,"title":"Education & Resources","content":"<p>Whether you\u2019re new to trading or a seasoned professional, our learning resources, webinars,\r\nand market insights help you sharpen your skills and grow as a trader.<\/p>","order":7,"status":true,"created_at":"2025-10-31T11:35:34.000000Z","updated_at":"2025-10-31T11:35:34.000000Z","deleted_at":null}],"advantages":[{"id":194,"customer_id":168,"title":"Forex","content":"<p><span style=\"color: rgb(176, 176, 176); font-family: Manrope, system-ui, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;\">The\r\n foreign exchange market is the most liquid market in the world, \r\noffering around-the-clock access and tight spreads. Our forex offerings \r\ncover all major pairs, minors, and a wide selection of exotics, \r\nproviding opportunities for both day traders and long-term strategists. \r\nWith low latency execution and high leverage options, our platform \r\nallows you to act quickly in a fast-moving market.<\/span><\/p>","image":null,"status":true,"order":1,"created_at":"2025-12-08T13:46:18.000000Z","updated_at":"2025-12-08T13:46:18.000000Z","deleted_at":null},{"id":195,"customer_id":168,"title":"Commodities","content":"<p><span style=\"color: rgb(176, 176, 176); font-family: Manrope, system-ui, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;\">Commodities\r\n like gold, oil, and silver offer traders a hedge against inflation and \r\nmarket volatility. These assets often behave independently of stocks and\r\n currencies, making them excellent tools for diversification. Our \r\ncommodity instruments are traded with competitive pricing and fast \r\nexecution, allowing you to tap into global supply and demand shifts with\r\n confidence.<\/span><\/p>","image":null,"status":true,"order":2,"created_at":"2025-12-08T13:46:42.000000Z","updated_at":"2025-12-08T13:46:42.000000Z","deleted_at":null},{"id":196,"customer_id":168,"title":"Stocks","content":"<p><span style=\"color: rgb(176, 176, 176); font-family: Manrope, system-ui, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;\">Trade\r\n shares of top-performing companies from leading global exchanges. Our \r\nstock instruments allow you to speculate on price movements without \r\nowning the underlying asset, giving you the flexibility to go long or \r\nshort. Enjoy access to major sectors like tech, healthcare, energy, and \r\nmore\u2014empowering you to build strategies based on corporate performance \r\nand market momentum.<\/span><\/p>","image":null,"status":true,"order":3,"created_at":"2025-12-08T13:47:08.000000Z","updated_at":"2025-12-08T13:47:08.000000Z","deleted_at":null},{"id":197,"customer_id":168,"title":"Indices","content":"<p><span style=\"color: rgb(176, 176, 176); font-family: Manrope, system-ui, -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, sans-serif;\">Indices\r\n represent the performance of a group of stocks, making them a powerful \r\nway to gain broad market exposure. Whether you're trading the S&amp;P \r\n500, NASDAQ, FTSE, or other major indices, our platform provides \r\nefficient access with low latency and advanced charting tools. Indices \r\nare ideal for traders seeking to take positions on broader economic \r\ntrends rather than individual companies.<\/span><\/p>","image":null,"status":true,"order":4,"created_at":"2025-12-08T13:47:34.000000Z","updated_at":"2025-12-08T13:47:34.000000Z","deleted_at":null},{"id":198,"customer_id":168,"title":"Cryptocurrencies","content":"<p>Cryptocurrencies offer a dynamic, 24\/7 market driven by innovation and global demand. Our crypto offerings include leading assets like Bitcoin, Ethereum, and a broad range of emerging altcoins, giving traders access to both established and high-growth opportunities. With fast execution, competitive spreads, and advanced security, our platform empowers you to trade confidently in one of the world\u2019s most rapidly evolving markets.<\/p>","image":null,"status":true,"order":5,"created_at":"2025-12-10T13:25:07.000000Z","updated_at":"2025-12-10T13:25:07.000000Z","deleted_at":null}]}]